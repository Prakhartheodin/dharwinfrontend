# Backend origin (no /v1) — OAuth / rewrites target (see next.config.js)
BACKEND_URL=http://localhost:3000
# Deployed: BACKEND_URL=https://apis.dharwinone.com

# API base (must include /v1). Deployed UAT/production:
NEXT_PUBLIC_API_URL=https://apis.dharwinone.com/v1/
# Local: same-origin proxy — NEXT_PUBLIC_API_URL=/api/v1
# Local: direct backend — NEXT_PUBLIC_API_URL=http://localhost:3000/v1/

# Frontend URL for share links (job URLs, etc.) - used at build/SSR time
# Production: must match your deployed frontend URL for correct share links
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001
# Production: NEXT_PUBLIC_FRONTEND_URL=https://dharwinone.com

# LiveKit Configuration - must match backend (use Cloud URL when using LiveKit Cloud)
NEXT_PUBLIC_LIVEKIT_URL=wss://dharwin-w82omxlx.livekit.cloud
