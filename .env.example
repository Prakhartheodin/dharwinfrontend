# Copy to .env and adjust. NEXT_PUBLIC_* are exposed to the browser.

# Production / deployed API (default for cloud builds)
NEXT_PUBLIC_API_URL=https://apis.dharwinone.com/v1/

# Local Express backend:
# NEXT_PUBLIC_API_URL=http://localhost:3000/v1/

# Same-origin proxy (next.config rewrites → backend):
# NEXT_PUBLIC_API_URL=/api/v1

# Optional: explicit rewrite target if different from deriving host from NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_API_BACKEND_URL=https://apis.dharwinone.com

# LiveKit — must match backend; use your Cloud or self-hosted WSS URL
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
