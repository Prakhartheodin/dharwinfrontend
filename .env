# Deployed backend API (UAT / production)
NEXT_PUBLIC_API_URL=https://apis.dharwinone.com/v1/

# Local dev alternatives (uncomment one):
# Same-origin proxy (next.config rewrites → backend; better for HttpOnly cookies on localhost)
# NEXT_PUBLIC_API_URL=/api/v1
# Direct local Express:
# NEXT_PUBLIC_API_URL=http://localhost:3000/v1/

# LiveKit Configuration - must match backend (use Cloud URL when using LiveKit Cloud)
NEXT_PUBLIC_LIVEKIT_URL=wss://dharwin-w82omxlx.livekit.cloud
